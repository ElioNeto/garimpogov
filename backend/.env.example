# =============================================================================
# GarimpoGov - Backend Environment Variables
# =============================================================================
# Copie este arquivo para .env e preencha os valores antes de rodar localmente.
# No Railway, configure essas variaveis em:
#   Project -> Service -> Variables
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/garimpogov
# Railway: copie a URL gerada pelo servico PostgreSQL do Railway
#   (ex: postgresql+asyncpg://postgres:xxxx@containers-us-west-xx.railway.app:5432/railway)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/garimpogov

# -----------------------------------------------------------------------------
# GOOGLE GEMINI AI
# -----------------------------------------------------------------------------
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# CLOUDFLARE R2 (armazenamento de PDFs)
# -----------------------------------------------------------------------------
# Crie um bucket R2 em: https://dash.cloudflare.com -> R2 Object Storage
# Crie um API Token com permissao de leitura/escrita no bucket
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# Formato: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET_NAME=garimpogov-editais

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Local: http://localhost:5173
# Producao (Railway): URL publica do seu servico frontend
#   ex: https://garimpogov-frontend.up.railway.app
FRONTEND_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# APP CONFIG (opcional)
# -----------------------------------------------------------------------------
# Porta do servidor (Railway define automaticamente via $PORT)
PORT=8000
