# =============================================================================
# GarimpoGov - Frontend Environment Variables
# =============================================================================
# Copie este arquivo para .env e preencha antes de rodar localmente.
# No Railway, configure em: Project -> Service -> Variables
# IMPORTANTE: variaveis do Vite DEVEM comecar com VITE_
# =============================================================================

# URL base da API backend
# Local: http://localhost:8000
# Producao (Railway): URL publica do seu servico backend
#   ex: https://garimpogov-api.up.railway.app
VITE_API_URL=http://localhost:8000
